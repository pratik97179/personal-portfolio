{
  "name": "pratik-portfolio",
  "version": "0.1.0",
  "packageManager": "bun@1.3.11",
  "description": "Personal portfolio for Pratik Nath Tiwari",
  "private": true,
  "author": "Pratik Nath Tiwari",
  "license": "MIT",
  "keywords": [
    "personal site",
    "portfolio",
    "Next.js",
    "Pratik Nath Tiwari",
    "software engineer"
  ],
  "scripts": {
    "dev": "next dev",
    "postinstall": "node scripts/repair-typescript.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "check": "bun run lint && bun run typecheck && bun run test",
    "build": "node scripts/build-overview.mjs",
    "build:next": "next build",
    "ogbuild": "next build",
    "start": "next start",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "typecheck": "node scripts/repair-typescript.mjs && tsgo --noEmit",
    "format": "oxfmt --check",
    "format:fix": "oxfmt"
  },
  "engines": {
    "node": "24.x"
  },
  "browserslist": [
    "last 2 Chrome versions",
    "last 2 Firefox versions",
    "last 2 Safari versions",
    "last 2 Edge versions"
  ],
  "dependencies": {
    "@microflash/remark-callout-directives": "^5.0.0",
    "@radix-ui/react-slot": "^1.2.4",
    "@t3-oss/env-nextjs": "^0.13.10",
    "@tailwindcss/postcss": "^4.1.18",
    "@tailwindcss/typography": "^0.5.19",
    "@tanstack/react-query": "^5.90.12",
    "@types/node": "20.11.17",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.1",
    "geist": "1.2.2",
    "gray-matter": "^4.0.3",
    "lucide-react": "^0.562.0",
    "motion": "^12.40.0",
    "next": "^16.3.0-canary.83",
    "next-mdx-remote": "^6.0.0",
    "postcss": "^8.4.35",
    "react": "19",
    "react-dom": "19",
    "react-icons": "^5.5.0",
    "react-markdown": "^10.1.0",
    "react-syntax-highlighter": "^16.1.0",
    "rehype-mdx-code-props": "^3.0.1",
    "rehype-raw": "^7.0.0",
    "remark-directive": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "sonner": "^1.5.0",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4.1.18",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.9.3",
    "unist-util-visit": "^5.0.0",
    "vaul": "^1.1.2",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@types/react": "19",
    "@types/react-dom": "19",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@typescript/native-preview": "^7.0.0-dev.20260707.2",
    "@vitest/coverage-v8": "^4.1.2",
    "babel-plugin-react-compiler": "^1.0.0",
    "drizzle-kit": "^0.31.8",
    "jsdom": "^29.0.1",
    "oxfmt": "^0.33.0",
    "oxlint": "^1.43.0",
    "postgres": "^3.4.9",
    "vitest": "^4.1.2"
  }
}
